# Auto-detect text files and perform LF normalization
* text=auto

# Python and scripts
*.py text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Virtual environments (binary)
**/phi4_env/** binary
**/venv/** binary
**/env/** binary
**/__pycache__/** binary
**/*.pyc binary

# Databases (binary)
*.db binary
*.sqlite binary
*.sqlite3 binary

# Images (binary)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary

# Archives and compression (binary)
*.zip binary
*.tar binary
*.gz binary
*.bz2 binary
*.xz binary
*.7z binary
*.rar binary

# Compiled binaries (binary)
*.so binary
*.dylib binary
*.dll binary
*.exe binary
*.o binary
*.a binary

# Model files (binary)
*.model binary
*.bin binary
*.pt binary
*.pth binary
*.pkl binary
*.pickle binary
*.joblib binary

# Audio/Video (binary)
*.wav binary
*.mp3 binary
*.mp4 binary
*.m4a binary
*.mov binary
*.avi binary

# Office documents (binary)
*.docx binary
*.xlsx binary
*.pptx binary
*.doc binary
*.xls binary
*.ppt binary
