# -----------------------------------------
# 🔥 Runtime directories – overlay, solver, keylogger
# -----------------------------------------
overlay/data/                     # overlay browser session (cookies, cache, etc.)
overlay-venv/                     # overlay virtual environment
apps/keylogger/keylogs/           # keylogger JSONL logs
solver/temp/                      # solver screenshots & OCR temp files
solver/log/                       # solver Flask logs
solver/venv/                      # solver virtual environment
